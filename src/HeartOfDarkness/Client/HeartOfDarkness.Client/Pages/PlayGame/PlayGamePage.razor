@page "/play"
@inherits PlayGamePageBase
@using HeartOfDarkness.Client.Pages.Components.Map
@using HeartOfDarkness.Client.Pages.Components.Matrix

@if(PageState == DisplayState.Map)
{
    <MapComponent MapState=Game.MapState MapDefinition=GameDefinition.MapDefinition>
        <MapRegionTokenComponent Image=PlayerColourDefinition.ExplorerToken RegionDefinition=PlayerRegionDefinition />
        <TurnTrackComponent GameDefinition=GameDefinition GameState=Game />
    </MapComponent>
}
else if (PageState == DisplayState.Matrix) 
{
    <MatrixComponent Game=Game MatrixDefinition=GameDefinition.MatrixDefinition PlayerColourDefinition=PlayerColourDefinition />
}
